SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_SITE_NAME=Makerspace Manager
DATABASE_URL=postgres://makerspace:makerspace@localhost:5432/makerspace_manager
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173
HMAC_CLIENT_ID=
HMAC_SECRET=
HMAC_MAX_CLOCK_SKEW_SECONDS=300
HMAC_PROTECTED_PATH_PREFIXES=/api/public/,/api/v1/public/
# Fernet key for ApiClient, Telegram bot token, and makerspace SMTP password
# encryption. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_CLIENT_ENC_KEY=
DEVICE_ATTESTATION_APPS={}
DEVICE_APPLE_ATTESTATION_VERIFY_URL=
DEVICE_APPLE_ATTESTATION_VERIFY_TOKEN=
DEVICE_ANDROID_ATTESTATION_VERIFY_URL=
DEVICE_ANDROID_ATTESTATION_VERIFY_TOKEN=
DEVICE_ATTESTATION_CHALLENGE_TTL_SECONDS=180
DEVICE_ATTESTATION_PROVIDER_TIMEOUT_SECONDS=10
THROTTLE_DEVICE_ATTESTATION_CHALLENGE=5/min
THROTTLE_DEVICE_LOGIN=5/min
THROTTLE_DEVICE_LOGIN_USER=10/hour
THROTTLE_DEVICE_REFRESH=30/min
THROTTLE_PUSH_DEVICE_REGISTRATION=10/min
# Independent 32+ character HMAC key; do not reuse an API or provider credential.
PUSH_TOKEN_HMAC_KEY=
# Stripe Connect OAuth callback. Empty keeps managed Connect dormant.
STRIPE_CONNECT_REDIRECT_URI=

# Production (separate HTTPS origins): leave defaults (SameSite=None, Secure=True).
# Local dev: serve the frontend via a same-origin Vite proxy to :8000 and set:
# AUTH_COOKIE_SAMESITE=Lax
# AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_SECURE=True

# MinIO evidence storage for host-dev. For a dockerized backend, use the internal
# endpoint (http://minio:9000) for AWS_S3_ENDPOINT_URL and the public endpoint
# (http://localhost:9000) for AWS_S3_PUBLIC_ENDPOINT_URL; out of scope this phase.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=evidence
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
EVIDENCE_URL_TTL_SECONDS=300
EVIDENCE_MAX_BYTES=10485760
# Private machine and maintenance document formats (comma-separated).
MACHINE_DOC_ALLOWED_EXT=pdf,jpg,jpeg,png,webp,stl,3mf,step,stp,obj,amf,ply,gcode,gco,iges,igs,dxf
MACHINE_DOC_ALLOWED_MIME=application/pdf,image/jpeg,image/png,image/webp,application/octet-stream,model/stl,application/sla,application/vnd.ms-pki.stl,model/3mf,application/vnd.ms-package.3dmanufacturing-3dmodel+xml,application/vnd.ms-3mfdocument,application/step,model/step,model/obj,application/xml,text/xml,application/x-amf,model/amf,application/x-ply,model/ply,text/x.gcode,application/x-gcode,application/iges,model/iges,image/vnd.dxf,application/dxf,application/x-dxf,text/plain
# Private print model/CAD/toolpath formats (comma-separated).
PRINT_ALLOWED_MODEL_EXT=stl,3mf,step,stp,obj,amf,ply,gcode,gco,iges,igs,dxf
PRINT_ALLOWED_MODEL_MIME=application/octet-stream,model/stl,application/sla,application/vnd.ms-pki.stl,model/3mf,application/vnd.ms-package.3dmanufacturing-3dmodel+xml,application/vnd.ms-3mfdocument,application/step,model/step,model/obj,application/xml,text/xml,application/x-amf,model/amf,application/x-ply,model/ply,text/x.gcode,application/x-gcode,application/iges,model/iges,image/vnd.dxf,application/dxf,application/x-dxf,text/plain
# Public catalog images use a separate anonymous-read bucket. Never store
# private evidence or handover photos here.
PUBLIC_IMAGE_BUCKET=public-images
PUBLIC_IMAGE_BASE_URL=http://localhost:9000/public-images
PUBLIC_IMAGE_MAX_BYTES=5242880
PUBLIC_IMAGE_URL_TTL_SECONDS=300

# Public request workflow throttle scopes.
THROTTLE_REQUEST_SUBMIT=10/min
THROTTLE_REQUEST_STATUS=60/min

# Email defaults use the console backend for local development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Makerspace Manager <noreply@makerspace-manager.local>

# Telegram. Per-makerspace bot tokens + group chat ids live in the DB; these are the
# optional global fallback bot and the webhook auth secret. TELEGRAM_WEBHOOK_SECRET must
# be set for accept/reject webhook callbacks to be trusted — the webhook fails closed
# (rejects every callback) when it is unset.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
